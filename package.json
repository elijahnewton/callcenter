{
  "name": "cloudcall",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:worker\" \"npm run dev:frontend\"",
    "dev:worker": "wrangler dev --local",
    "dev:frontend": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 execute cloudcall-db --local --file=./src/db/schema.sql",
    "db:migrate:remote": "wrangler d1 execute cloudcall-db --remote --file=./src/db/schema.sql"
  },
  "dependencies": {
    "@clerk/backend": "^1.8.4",
    "@clerk/clerk-react": "^5.4.1",
    "hono": "^4.4.6",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240529.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.12",
    "wrangler": "^3.57.1"
  }
}